  <section class="card code-box">
    <h2>💻 Arduino Kod: LED Blink</h2>

    <pre>
int led = 13;

void setup() {
  pinMode(led, OUTPUT);
}

void loop() {
  digitalWrite(led, HIGH);
  delay(1000);
  digitalWrite(led, LOW);
  delay(1000);
}
    </pre>
